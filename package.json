{
	"name": "opinion-parser-cf",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"predev": "vite build --config src/frontend/vite.config.ts",
		"dev": "wrangler dev",
		"dev:frontend": "vite --config src/frontend/vite.config.ts",
		"build:frontend": "vite build --config src/frontend/vite.config.ts",
		"deploy": "bun run build:frontend && wrangler deploy",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"typecheck:frontend": "tsc --noEmit -p tsconfig.frontend.json"
	},
	"dependencies": {
		"hono": "^4.12.9",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.9",
		"@cloudflare/vitest-pool-workers": "^0.13.5",
		"@cloudflare/workers-types": "^4.20260317.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"lefthook": "^2.1.4",
		"typescript": "^5.7.0",
		"vite": "^8.0.3",
		"vitest": "^4.1.2",
		"wrangler": "^4.78.0"
	}
}
