{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"skipLibCheck": true,
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"isolatedModules": true,
		"noEmit": true,
		"forceConsistentCasingInFileNames": true,
		"paths": { "@/*": ["./src/*"] }
	},
	"include": ["src/frontend/**/*.tsx", "src/frontend/**/*.ts"],
	"exclude": ["node_modules", "dist"]
}
